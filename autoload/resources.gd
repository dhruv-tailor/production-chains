func get_resource(resource_name: String) -> Dictionary:
	return RESOURCES.get(resource_name, {})

func get_resources_by_type(type: Constants.resourceType) -> Dictionary:
	var result: Dictionary = {}
	for key in RESOURCES:
		if RESOURCES[key]["type"] == type:
			result[key] = RESOURCES[key]
	return result

func get_resources_by_subtype(subtype: Constants.resourceSubType) -> Dictionary:
	var result: Dictionary = {}
	for key in RESOURCES:
		if RESOURCES[key]["subtype"] == subtype:
			result[key] = RESOURCES[key]
	return result
